{
  "name": "@archmap/icons",
  "version": "0.1.1",
  "description": "Opt-in third-party service icon pack for ArchMap diagrams.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "generate:catalog": "node scripts/generate-catalog.mjs",
    "generate:cloud-icons": "node scripts/generate-cloud-icons.mjs",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "npm run typecheck && npm run build && node scripts/test-icons.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "simple-icons": "^16.24.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "keywords": [
    "archmap",
    "architecture",
    "diagram",
    "icons"
  ],
  "license": "MIT"
}
